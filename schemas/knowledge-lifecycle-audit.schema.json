{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/knowledge-lifecycle-audit.schema.json",
  "title": "Knowledge Lifecycle Audit",
  "description": "Audits the end-to-end lifecycle of a knowledge unit across origin retention, retention decisions, derivative reasoning, rehydration, rollback, promotion, quarantine, and disposal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "subject",
    "audit_window",
    "record_bindings",
    "lifecycle_events",
    "control_results",
    "findings",
    "assessment",
    "policy_snapshot",
    "trace"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.5.0"
    },
    "audit_id": {
      "$ref": "#/$defs/identifier"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "knowledge_id",
        "label",
        "description"
      ],
      "properties": {
        "knowledge_id": {
          "$ref": "#/$defs/identifier"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      }
    },
    "audit_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_at",
        "ended_at"
      ],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "record_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/recordBinding"
      }
    },
    "lifecycle_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lifecycleEvent"
      }
    },
    "control_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/controlResult"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_status",
        "terminal_state",
        "open_finding_ids",
        "audit_confidence",
        "issued_at",
        "issued_by"
      ],
      "properties": {
        "overall_status": {
          "type": "string",
          "enum": [
            "compliant",
            "conditional",
            "non-compliant"
          ]
        },
        "terminal_state": {
          "$ref": "#/$defs/lifecycleState"
        },
        "open_finding_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "audit_confidence": {
          "$ref": "#/$defs/score"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "issued_by": {
          "$ref": "#/$defs/identifier"
        },
        "next_review_at": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      }
    },
    "policy_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_record_types",
        "require_verified_record_bindings",
        "require_contiguous_event_chain",
        "require_acyclic_event_order",
        "require_closed_expired_temporary_integrations",
        "prohibit_unapproved_irreversible_discard",
        "require_terminal_state_consistency",
        "maximum_open_error_findings"
      ],
      "properties": {
        "required_record_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/recordType"
          }
        },
        "require_verified_record_bindings": {
          "type": "boolean"
        },
        "require_contiguous_event_chain": {
          "type": "boolean"
        },
        "require_acyclic_event_order": {
          "type": "boolean"
        },
        "require_closed_expired_temporary_integrations": {
          "type": "boolean"
        },
        "prohibit_unapproved_irreversible_discard": {
          "type": "boolean"
        },
        "require_terminal_state_consistency": {
          "type": "boolean"
        },
        "maximum_open_error_findings": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "created_by",
        "parent_record_ids"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "$ref": "#/$defs/identifier"
        },
        "parent_record_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sha256Hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "recordType": {
      "type": "string",
      "enum": [
        "minimal-origin-knowledge-record",
        "knowledge-retention-decision",
        "derivative-reasoning-trace",
        "knowledge-rehydration-record"
      ]
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "absent",
        "active",
        "archived",
        "temporary",
        "quarantined",
        "discarded"
      ]
    },
    "recordBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "record_type",
        "record_id",
        "relationship",
        "verified"
      ],
      "properties": {
        "binding_id": {
          "$ref": "#/$defs/identifier"
        },
        "record_type": {
          "$ref": "#/$defs/recordType"
        },
        "record_id": {
          "$ref": "#/$defs/identifier"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "origin-definition",
            "retention-decision",
            "reasoning-use",
            "rehydration-operation"
          ]
        },
        "verified": {
          "type": "boolean"
        },
        "content_hash": {
          "$ref": "#/$defs/sha256Hash"
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "lifecycleEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "sequence",
        "event_type",
        "record_binding_id",
        "occurred_at",
        "state_before",
        "state_after",
        "reversible",
        "evidence_refs"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/identifier"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "event_type": {
          "type": "string",
          "enum": [
            "origin-declared",
            "retained",
            "archived",
            "discarded",
            "quarantined",
            "derivation-used",
            "rehydration-requested",
            "rehydrated",
            "expired",
            "rolled-back",
            "promoted"
          ]
        },
        "record_binding_id": {
          "$ref": "#/$defs/identifier"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "state_before": {
          "$ref": "#/$defs/lifecycleState"
        },
        "state_after": {
          "$ref": "#/$defs/lifecycleState"
        },
        "reversible": {
          "type": "boolean"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "approval_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "controlResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_id",
        "control_type",
        "status",
        "evidence_refs",
        "details"
      ],
      "properties": {
        "control_id": {
          "$ref": "#/$defs/identifier"
        },
        "control_type": {
          "type": "string",
          "enum": [
            "origin-lineage",
            "retention-policy",
            "derivation-trace",
            "rehydration-safety",
            "temporal-order",
            "terminal-state"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "warning",
            "not-applicable"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "details": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "severity",
        "category",
        "description",
        "related_event_ids",
        "remediation_required",
        "status"
      ],
      "properties": {
        "finding_id": {
          "$ref": "#/$defs/identifier"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "lineage",
            "policy",
            "trace",
            "integrity",
            "temporal",
            "lifecycle"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "related_event_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "remediation_required": {
          "type": "boolean"
        },
        "remediation_action": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "resolved",
            "accepted-risk"
          ]
        }
      }
    }
  }
}
